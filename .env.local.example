# ============================================================
# .env.local — 이 파일을 복사해서 .env.local로 이름을 바꾸고
#              실제 값을 채워 넣으세요. (절대 Git에 커밋 금지!)
# ============================================================

# Supabase 프로젝트 URL
# Supabase 대시보드 → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Supabase anon (public) key — 클라이언트 사이드용
# Supabase 대시보드 → Settings → API → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase Service Role Key — 서버 사이드 전용 (절대 브라우저에 노출 금지)
# Supabase 대시보드 → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 이 Next.js 서버의 공개 URL (QR 코드에 삽입될 다운로드 페이지 기준 URL)
# 로컬 개발: http://localhost:3000
# 배포 후:   https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 키오스크 프론트엔드(Vite) URL — CORS 허용 목록
CLIENT_URL=http://localhost:5173
